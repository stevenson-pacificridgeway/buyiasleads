# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend Configuration (used in checkout.html via environment)
VITE_STRIPE_PUBLIC_KEY=pk_live_YOUR_LIVE_PUBLIC_KEY_HERE
VITE_BACKEND_URL=https://buyiasleads-production.up.railway.app

# Email / Fulfillment (powers the automatic welcome + order-notification emails
# sent by the /webhook handler after a successful payment). If SENDGRID_API_KEY
# is left unset, the server logs the order and skips email (no crash).
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@buyiasleads.com   # must be a SendGrid-verified sender
# OWNER_NOTIFY_EMAIL=stevenson@pacificridgewayinsurance.com   # where new-order alerts go

# Twilio SMS (texts you on each new order + intake form submission). If these are
# left unset, the server logs the order and skips the text (no crash).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=+16193748111        # your Twilio phone number
# OWNER_NOTIFY_PHONE=+1XXXXXXXXXX         # your cell, where the texts go
